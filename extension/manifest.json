{
  "manifest_version": 3,
  "name": "Narrador Web (offline)",
  "version": "0.1.0",
  "permissions": ["activeTab","scripting","storage","offscreen"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "background": { "service_worker": "service_worker.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["ui.css"],
    "run_at": "document_idle"
  }]
}
